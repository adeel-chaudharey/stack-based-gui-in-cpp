  <property name="styleSheet">
   <string notr="true">/* =====================================================
   MAIN WINDOW
===================================================== */
QMainWindow {
    background-color: #020617;
    color: #E5E7EB;
    font-family: &quot;Segoe UI&quot;, &quot;Inter&quot;, sans-serif;
}

/* =====================================================
   LABELS
===================================================== */
QLabel {
    color: #CBD5F5;
    font-size: 14px;
    font-weight: 500;
}

/* =====================================================
   INPUT &amp; RESULT LINE EDITS
===================================================== */
QLineEdit {
    background-color: #1E293B;
    color: #E5E7EB;
    border: 1px solid #334155;
    border-radius: 10px;
    padding: 8px;
    font-size: 14px;
}

QLineEdit:focus {
    border: 1px solid #3B82F6;
}

/* =====================================================
   BUTTONS (POSTFIX / PREFIX)
===================================================== */
QPushButton {
    background-color: #3B82F6;
    color: white;
    border-radius: 10px;
    padding: 10px;
    font-size: 14px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #2563EB;
}

QPushButton:pressed {
    background-color: #1D4ED8;
}

/* =====================================================
   EVALUATE BUTTON (GREEN)
   objectName = btnEvaluate
===================================================== */
QPushButton#btnEvaluate {
    background-color: #22C55E;
}

QPushButton#btnEvaluate:hover {
    background-color: #16A34A;
}

/* =====================================================
   HISTORY LIST (QListWidget)
===================================================== */
QListWidget {
    background-color: #020617;
    border: 1px solid #334155;
    border-radius: 12px;
    padding: 6px;
    color: #E5E7EB;
}

QListWidget::item {
    padding: 8px;
    border-radius: 6px;
}

QListWidget::item:selected {
    background-color: #1E293B;
}

/* =====================================================
   SCROLL BAR (MODERN)
===================================================== */
QScrollBar:vertical {
    background: #020617;
    width: 10px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: #334155;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: #475569;
}

/* =====================================================
   MESSAGE BOX
===================================================== */
QMessageBox {
    background-color: #020617;
    color: #E5E7EB;
}

QMessageBox QPushButton {
    background-color: #3B82F6;
    border-radius: 8px;
    padding: 6px;
}

</string>
  </property>
  <property name="animated">
