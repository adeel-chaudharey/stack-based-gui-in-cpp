  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">/* ===============================
   MAIN WINDOW BACKGROUND
=============================== */
QMainWindow {
    background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #020617,
        stop:1 #020617
    );
}

/* ===============================
   CENTRAL GLASS CARD
=============================== */
QWidget#centralwidget {
    background: rgba(15, 23, 42, 0.78);   /* glass */
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.08);
}

/* ===============================
   LABELS (Expression / Result / History)
=============================== */
QLabel {
    color: #CBD5F5;
    font-size: 14px;
    font-weight: 500;
}

/* ===============================
   INPUT &amp; RESULT LINE EDIT
=============================== */
QLineEdit {
    background: rgba(30, 41, 59, 0.9);
    color: #F8FAFC;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.12);
    padding: 10px;
    font-size: 14px;
}
QLineEdit:hover {
    border: 1px solid #3B82F6;
}
QLineEdit:focus {
    border: 1px solid #60A5FA;
    background: rgba(30, 41, 59, 1);
}

/* ===============================
   BUTTONS (Postfix / Prefix)
=============================== */
QPushButton {
    background: rgba(59, 130, 246, 0.85);
    color: white;
    border-radius: 14px;
    padding: 10px;
    font-size: 14px;
    font-weight: 600;
    border: none;
}
QPushButton:hover {
    background: rgba(59, 130, 246, 1);
}
QPushButton:pressed {
    background: rgba(37, 99, 235, 1);
}

/* ===============================
   EVALUATE BUTTON (PRIMARY CTA)
=============================== */
QPushButton#btnEvaluate {
    background: rgba(34, 197, 94, 0.9);
    font-size: 15px;
}
QPushButton#btnEvaluate:hover {
    background: rgba(22, 163, 74, 1);
}
QPushButton#btnEvaluate:pressed {
    background: rgba(21, 128, 61, 1);
}

/* ===============================
   HISTORY LIST (GLASS PANEL)
=============================== */
QListWidget {
    background: rgba(2, 6, 23, 0.75);
    border-radius: 14px;
    padding: 8px;
    color: #E5E7EB;
    border: 1px solid rgba(255,255,255,0.08);
}
QListWidget::item {
    padding: 6px;
    border-radius: 8px;
}
QListWidget::item:hover {
    background: rgba(59, 130, 246, 0.18);
}
QListWidget::item:selected {
    background: rgba(59, 130, 246, 0.30);
}

/* ===============================
   SCROLLBAR (MINIMAL)
=============================== */
QScrollBar:vertical {
    background: transparent;
    width: 6px;
}
QScrollBar::handle:vertical {
    background: rgba(148, 163, 184, 0.4);
    border-radius: 3px;
}
QScrollBar::handle:vertical:hover {
    background: rgba(148, 163, 184, 0.7);
}
</string>
